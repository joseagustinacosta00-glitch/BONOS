# FastAPI / market source
MARKET_SOURCE=mock

# pyRofex credentials. Required only with MARKET_SOURCE=pyrofex.
# Use ROFEX_ENVIRONMENT=REMARKET for demo or ROFEX_ENVIRONMENT=LIVE for production.
ROFEX_REST_URL=https://api.VETA.xoms.com.ar/
ROFEX_WS_URL=wss://api.VETA.xoms.com.ar/
ROFEX_ENVIRONMENT=LIVE
ROFEX_USER=
ROFEX_PASSWORD=
ROFEX_ACCOUNT=

# Matba Rofex / Primary symbols for MERV bonds usually include market, segment,
# ticker and settlement. Adjust this if get_all_instruments shows a different format.
ROFEX_MARKET=ROFEX
ROFEX_SETTLEMENT=24hs
ROFEX_SETTLEMENT_T0=CI
ROFEX_SETTLEMENT_T1=24hs
ROFEX_SYMBOL_TEMPLATE=MERV - XMEV - {symbol} - {settlement}
# Comma-separated caucion ARS tickers. The app uses the one with fewer calendar days.
ROFEX_CAUCION_SYMBOLS=PESOS - 1D,PESOS - 4D

# BCRA public API.
BCRA_BASE_URL=https://api.bcra.gob.ar
BCRA_CACHE_TTL_SECONDS=21600

# Local user data. Keep this file out of git if it contains real saved data.
APP_DB_PATH=data/user_data.db

# Optional AI assistant integration. Keep real keys outside git.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Postgres for own market history pipeline. If empty, the pipeline is disabled
# and the app keeps working without persistence of ticks.
DATABASE_URL=
MARKET_HISTORY_ENABLED=true
MARKET_OPEN_LOCAL=10:30
MARKET_CLOSE_LOCAL=17:00
MARKET_HISTORY_BATCH_SECONDS=15
